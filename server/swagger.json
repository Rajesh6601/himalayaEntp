{
  "openapi": "3.0.3",
  "info": {
    "title": "Himalaya Enterprises API",
    "description": "REST API for the Himalaya Enterprises B2B automobile body manufacturing platform. Supports product catalog, order/inquiry management, user authentication, and contact inquiries.",
    "version": "1.0.0",
    "contact": {
      "name": "Himalaya Enterprises",
      "email": "admin@himalayaentp.com"
    }
  },
  
  "servers": [
    { "url": "/api", "description": "Current server" }
  ],
  "tags": [
    { "name": "Health", "description": "Service health check" },
    { "name": "Auth", "description": "Authentication and registration" },
    { "name": "Products", "description": "Product catalog (CRUD for suppliers, read for all)" },
    { "name": "Orders", "description": "Inquiries and RFQs" },
    { "name": "Favorites", "description": "Buyer product favorites" },
    { "name": "Contact", "description": "Public contact form" },
    { "name": "Categories", "description": "Product categories" }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token obtained from /auth/login or /auth/register"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "role": { "type": "string", "enum": ["buyer", "supplier", "admin"] }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string", "description": "JWT token (expires in 24h)" },
          "user": { "$ref": "#/components/schemas/User" }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "tippers" },
          "name": { "type": "string", "example": "Tippers" },
          "description": { "type": "string" },
          "icon": { "type": "string", "example": "\ud83d\ude9b" },
          "sort_order": { "type": "integer" }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string", "example": "10-Wheeler Tipper Body" },
          "category_id": { "type": "string", "example": "tippers" },
          "category_name": { "type": "string", "example": "Tippers" },
          "specs": { "type": "string", "example": "Capacity: 16 cubic meters | High-tensile steel" },
          "description": { "type": "string" },
          "price_min": { "type": "string", "example": "285000.00" },
          "price_max": { "type": "string", "example": "350000.00" },
          "stock": { "type": "integer", "example": 5 },
          "status": { "type": "string", "enum": ["available", "production", "order"] },
          "icon": { "type": "string", "example": "\ud83d\ude9b" },
          "images": { "type": "array", "items": { "type": "string" }, "example": ["tipper.jpg"] },
          "created_by": { "type": "string", "format": "uuid" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "OrderItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "order_id": { "type": "string" },
          "product_id": { "type": "string", "format": "uuid", "nullable": true },
          "name": { "type": "string" },
          "category": { "type": "string", "nullable": true },
          "specs": { "type": "string", "nullable": true },
          "quantity": { "type": "integer", "default": 1 },
          "price": { "type": "string", "example": "285000.00" },
          "price_max": { "type": "string", "example": "350000.00" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "ORD-MP1GD6F4" },
          "buyer_id": { "type": "string", "format": "uuid" },
          "buyer_name": { "type": "string", "description": "Only included for supplier queries" },
          "buyer_email": { "type": "string", "description": "Only included for supplier queries" },
          "type": { "type": "string", "enum": ["inquiry", "rfq"] },
          "status": { "type": "string", "enum": ["pending", "confirmed", "in-progress", "completed", "cancelled"] },
          "notes": { "type": "string" },
          "total_value": { "type": "string", "example": "0.00" },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/OrderItem" } },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Returns API and database connection status.",
        "responses": {
          "200": {
            "description": "Healthy",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string", "example": "ok" }, "database": { "type": "string", "example": "connected" } } } } }
          },
          "500": {
            "description": "Database disconnected",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string", "example": "error" }, "database": { "type": "string", "example": "disconnected" } } } } }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login",
        "description": "Authenticate with email and password. Returns a JWT token valid for 24 hours.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "ramesh@example.com" },
                  "password": { "type": "string", "example": "buyer123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } }
          },
          "401": {
            "description": "Invalid credentials",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register",
        "description": "Create a new user account. Returns a JWT token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string", "example": "New User" },
                  "email": { "type": "string", "format": "email", "example": "newuser@example.com" },
                  "password": { "type": "string", "minLength": 1, "example": "securepass123" },
                  "role": { "type": "string", "enum": ["buyer", "supplier"], "default": "buyer" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registration successful",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } }
          },
          "409": {
            "description": "Email already registered",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
          }
        }
      }
    },
    "/products": {
      "get": {
        "tags": ["Products"],
        "summary": "List products",
        "description": "Retrieve all products with optional filtering by category, status, or search term.",
        "parameters": [
          { "name": "category", "in": "query", "schema": { "type": "string" }, "description": "Filter by category_id (e.g. `tippers`, `trailers`). Use `all` to skip." },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["available", "production", "order", "all"] }, "description": "Filter by product status" },
          { "name": "search", "in": "query", "schema": { "type": "string" }, "description": "Search in product name and specs (case-insensitive)" }
        ],
        "responses": {
          "200": {
            "description": "Product list",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Product" } } } }
          }
        }
      },
      "post": {
        "tags": ["Products"],
        "summary": "Create product",
        "description": "Create a new product. **Supplier role required.**",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "category_id", "price_min", "price_max"],
                "properties": {
                  "name": { "type": "string", "example": "New Tipper Body" },
                  "category_id": { "type": "string", "example": "tippers" },
                  "specs": { "type": "string", "example": "Capacity: 18 cubic meters" },
                  "description": { "type": "string", "example": "Heavy-duty tipper body" },
                  "price_min": { "type": "number", "example": 300000 },
                  "price_max": { "type": "number", "example": 400000 },
                  "stock": { "type": "integer", "default": 0, "example": 5 },
                  "status": { "type": "string", "enum": ["available", "production", "order"], "default": "available" },
                  "icon": { "type": "string", "default": "\ud83d\udce6", "example": "\ud83d\ude9b" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Product" } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "403": { "description": "Not a supplier", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Get product by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Product detail",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Product" } } }
          },
          "404": { "description": "Product not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "put": {
        "tags": ["Products"],
        "summary": "Update product",
        "description": "Update product fields. Omitted fields retain their current values. **Supplier role required.**",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "category_id": { "type": "string" },
                  "specs": { "type": "string" },
                  "description": { "type": "string" },
                  "price_min": { "type": "number" },
                  "price_max": { "type": "number" },
                  "stock": { "type": "integer" },
                  "status": { "type": "string", "enum": ["available", "production", "order"] },
                  "icon": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Product updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Product" } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "403": { "description": "Not a supplier", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Product not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["Products"],
        "summary": "Delete product",
        "description": "Permanently delete a product. **Supplier role required.**",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Product deleted",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string", "example": "Product deleted" } } } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "403": { "description": "Not a supplier", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/products/{id}/stock": {
      "patch": {
        "tags": ["Products"],
        "summary": "Update stock",
        "description": "Update product stock count. Status is automatically set to `available` if stock > 0, or `order` if stock is 0. **Supplier role required.**",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["stock"],
                "properties": {
                  "stock": { "type": "integer", "example": 10 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stock updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Product" } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "403": { "description": "Not a supplier", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Product not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/orders": {
      "get": {
        "tags": ["Orders"],
        "summary": "List orders",
        "description": "Buyers see their own orders. Suppliers see all orders with buyer name and email. Each order includes its line items.",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Order list",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Order" } } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "post": {
        "tags": ["Orders"],
        "summary": "Create order / inquiry",
        "description": "Submit a product inquiry or RFQ. The order ID is auto-generated with prefix `ORD-` (inquiry) or `RFQ-` (rfq).",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["type", "items"],
                "properties": {
                  "type": { "type": "string", "enum": ["inquiry", "rfq"], "example": "inquiry" },
                  "items": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["name"],
                      "properties": {
                        "product_id": { "type": "string", "format": "uuid", "nullable": true, "description": "Link to existing product (optional for RFQs)" },
                        "name": { "type": "string", "example": "10-Wheeler Tipper Body" },
                        "category": { "type": "string", "example": "tippers" },
                        "specs": { "type": "string" },
                        "quantity": { "type": "integer", "default": 1, "example": 2 },
                        "price": { "type": "number", "default": 0, "example": 285000 },
                        "price_max": { "type": "number", "default": 0, "example": 350000 }
                      }
                    }
                  },
                  "notes": { "type": "string", "example": "Need delivery within 2 weeks" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "id": { "type": "string", "example": "ORD-MP1GD6F4" }, "status": { "type": "string", "example": "pending" } } } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/orders/{id}/status": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Update order status",
        "description": "Change the status of an order. **Supplier role required.**",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "example": "ORD-MP1GD6F4" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "type": "string", "enum": ["pending", "confirmed", "in-progress", "completed", "cancelled"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Order" } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "403": { "description": "Not a supplier", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Order not found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/favorites": {
      "get": {
        "tags": ["Favorites"],
        "summary": "List favorites",
        "description": "Get all products favorited by the authenticated user.",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Favorite products",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Product" } } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/favorites/{productId}": {
      "post": {
        "tags": ["Favorites"],
        "summary": "Add to favorites",
        "description": "Add a product to the user's favorites. Duplicate additions are silently ignored.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "productId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Added",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string", "example": "Added to favorites" } } } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      },
      "delete": {
        "tags": ["Favorites"],
        "summary": "Remove from favorites",
        "description": "Remove a product from the user's favorites.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "productId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Removed",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string", "example": "Removed from favorites" } } } } }
          },
          "401": { "description": "Not authenticated", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/contact": {
      "post": {
        "tags": ["Contact"],
        "summary": "Submit contact inquiry",
        "description": "Public endpoint for visitors to submit a contact form.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "message"],
                "properties": {
                  "name": { "type": "string", "example": "John Doe" },
                  "email": { "type": "string", "format": "email", "example": "john@example.com" },
                  "phone": { "type": "string", "example": "+91 93865 94403" },
                  "product_interest": { "type": "string", "example": "tippers" },
                  "message": { "type": "string", "example": "I am interested in tipper bodies for my fleet." }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Inquiry submitted",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "message": { "type": "string", "example": "Inquiry submitted" } } } } }
          }
        }
      }
    },
    "/categories": {
      "get": {
        "tags": ["Categories"],
        "summary": "List categories",
        "description": "Get all product categories ordered by sort_order.",
        "responses": {
          "200": {
            "description": "Category list",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Category" } } } }
          }
        }
      }
    }
  }
}
